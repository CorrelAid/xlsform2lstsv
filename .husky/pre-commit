#!/bin/sh

# Run quick validation before commit
echo "🔍 Running pre-commit validation..."

# Run ESLint on all source TypeScript files
echo "🧹 Running ESLint..."
npx eslint src --ext .ts

if [ $? -ne 0 ]; then
  echo "❌ ESLint found issues. Please fix them before committing."
  echo "💡 Tip: Run 'npm run lint:fix' to automatically fix many issues."
  exit 1
fi

# Check TypeScript compilation (quick check)
echo "📝 Checking TypeScript compilation..."
npx tsc --noEmit

if [ $? -ne 0 ]; then
  echo "❌ TypeScript compilation failed. Commit aborted."
  exit 1
fi

echo "✅ Pre-commit validation passed. Proceeding with commit."